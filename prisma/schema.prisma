// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  CARRIER
  ADMIN
  SUPERADMIN
}

enum OrderStatus {
  NEW
  SEARCHING
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole

  firstName String
  lastName  String
  phone     String

  avatarUrl String?

  companyName String?
  companyLogo String?

  city    String?
  country String?

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  refreshTokens  RefreshToken[]
  carrierProfile CarrierProfile?
  orders         Order[]         @relation("ClientOrders")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model CarrierProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  experienceYears Int
  transportType   String
  description     String?
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vehicles Vehicle[]
  orders   Order[]

  @@index([isApproved])
  @@index([transportType])
}

model Vehicle {
  id              String   @id @default(cuid())
  carrierId       String
  type            String
  brand           String
  model           String
  year            Int
  plateNumber     String
  capacityTons    Float
  cargoVolume     Float
  vehicleImageUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  carrier CarrierProfile @relation(fields: [carrierId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([carrierId, plateNumber])
  @@index([carrierId])
  @@index([type])
}

model Order {
  id                         String      @id @default(cuid())
  clientId                   String
  carrierId                  String?
  title                      String
  cargoType                  String
  weight                     Float
  volume                     Float
  origin                     String
  destination                String
  comment                    String?
  estimatedPrice             Float?
  estimatedDeliveryTime      Int?
  estimatedCarrierSearchTime Int?
  status                     OrderStatus @default(NEW)
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt

  client  User            @relation("ClientOrders", fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  carrier CarrierProfile? @relation(fields: [carrierId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([clientId])
  @@index([carrierId])
  @@index([status])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}
