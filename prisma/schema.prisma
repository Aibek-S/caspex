// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  CARRIER
  ADMIN
  SUPERADMIN
}

enum OrderStatus {
  NEW
  SEARCHING
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole

  firstName String
  lastName  String
  phone     String

  avatarUrl String?

  companyName String?
  companyLogo String?

  city    String?
  country String?

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  refreshTokens  RefreshToken[]
  carrierProfile CarrierProfile?
  orders         Order[]         @relation("ClientOrders")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model CarrierProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  experienceYears Int
  transportType   String
  description     String?
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vehicles Vehicle[]
  orders   Order[]

  @@index([isApproved])
  @@index([transportType])
}

model Vehicle {
  id              String   @id @default(cuid())
  carrierId       String
  type            String
  brand           String
  model           String
  year            Int
  plateNumber     String
  capacityTons    Float
  cargoVolume     Float
  vehicleImageUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  carrier CarrierProfile @relation(fields: [carrierId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([carrierId, plateNumber])
  @@index([carrierId])
  @@index([type])
}

model Order {
  id                         String      @id @default(cuid())
  clientId                   String
  carrierId                  String?
  title                      String
  cargoType                  String
  weight                     Float
  volume                     Float
  origin                     String
  originCity                 String?
  originCountry              String?
  destination                String
  destinationCity            String?
  destinationCountry         String?
  originLat                  Float?
  originLng                  Float?
  destinationLat             Float?
  destinationLng             Float?
  cargoPhotoUrl              String?
  productPhotoUrls           String[]    @default([])
  comment                    String?
  estimatedPrice             Float?
  estimatedDeliveryTime      Int?
  estimatedCarrierSearchTime Int?
  status                     OrderStatus @default(SEARCHING)
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt

  client         User            @relation("ClientOrders", fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  carrier        CarrierProfile? @relation(fields: [carrierId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  routes         Route[]
  trackingEvents OrderTracking[]

  @@index([clientId])
  @@index([carrierId])
  @@index([status])
  @@index([createdAt])
}

model Route {
  id              String   @id @default(cuid())
  orderId         String?
  distanceKm      Float
  durationMinutes Float
  geometry        Json
  createdAt       DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Checkpoint {
  id             String   @id @default(cuid())
  name           String   @unique
  loadPercent    Int      @default(0)
  avgWaitMinutes Int      @default(0)
  latitude       Float
  longitude      Float
  updatedAt      DateTime @updatedAt

  @@index([latitude, longitude])
}

model TrainSchedule {
  id               String   @id @default(cuid())
  stationName      String   @unique
  departuresPerDay Int      @default(0)
  currentLoad      Int      @default(0)
  avgDelayMinutes  Int      @default(0)
  latitude         Float
  longitude        Float
  updatedAt        DateTime @updatedAt

  @@index([latitude, longitude])
}

model CheckpointLoadSnapshot {
  id                String   @id @default(cuid())
  syncBatchId       String
  source            String
  checkpointName    String
  borderCountry     String?
  region            String?
  waitingAreaCount  Int      @default(0)
  activeTruckNumbers String[] @default([])
  entryTimes        String[] @default([])
  raw               Json
  fetchedAt         DateTime @default(now())

  @@index([syncBatchId])
  @@index([fetchedAt])
  @@index([checkpointName])
}

model OrderTracking {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  location  String?
  timestamp DateTime    @default(now())
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([timestamp])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}
